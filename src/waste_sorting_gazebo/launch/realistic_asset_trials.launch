<launch>
  <!--
    Randomized realistic Objaverse asset sorting trials.

    This launch:
      1. Starts Gazebo.
      2. Starts sort_executor.
      3. Runs randomized realistic asset trials.

    This evaluates:
      - prepared realistic asset loading
      - Gazebo spawning
      - pick_event publishing
      - sort_executor class-to-bin routing
      - final bin position correctness

    This does NOT evaluate YOLO accuracy.
    It evaluates realistic 3D sorting integration.
  -->

  <arg name="gui" default="true"/>
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>

  <arg name="trial_count" default="20"/>
  <arg name="class_mode" default="balanced"/>

  <arg name="static_model" default="true"/>
  <arg name="spawn_x" default="-0.65"/>
  <arg name="spawn_z" default="0.20"/>

  <arg name="random_y" default="true"/>
  <arg name="random_yaw" default="true"/>

  <arg name="event_delay_sec" default="0.50"/>
  <arg name="sort_wait_sec" default="0.80"/>

  <arg name="delete_before_each_trial" default="true"/>
  <arg name="delete_after_each_trial" default="false"/>

  <arg name="drop_z" default="0.20"/>

  <arg name="log_path" default="$(env HOME)/waste-sorting-robot-project/logs/trials/realistic_asset_trials.csv"/>

  <!-- Start Gazebo -->
  <include file="$(find waste_sorting_gazebo)/launch/sim.launch">
    <arg name="gui" value="$(arg gui)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
  </include>

  <!-- Start sort executor with final bin mapping -->
  <include file="$(find waste_sorting_gazebo)/launch/sort_executor.launch">
    <arg name="pick_event_topic" value="/waste/pick_event"/>
    <arg name="drop_z" value="$(arg drop_z)"/>
  </include>

  <!-- Run realistic trials -->
  <node
    pkg="waste_sorting_gazebo"
    type="run_realistic_asset_trials.py"
    name="run_realistic_asset_trials"
    output="screen"
    respawn="false">

    <param name="trial_count" value="$(arg trial_count)"/>
    <param name="class_mode" value="$(arg class_mode)"/>

    <param name="static_model" value="$(arg static_model)"/>
    <param name="spawn_x" value="$(arg spawn_x)"/>
    <param name="spawn_z" value="$(arg spawn_z)"/>

    <param name="random_y" value="$(arg random_y)"/>
    <param name="random_yaw" value="$(arg random_yaw)"/>

    <param name="event_delay_sec" value="$(arg event_delay_sec)"/>
    <param name="sort_wait_sec" value="$(arg sort_wait_sec)"/>

    <param name="delete_before_each_trial" value="$(arg delete_before_each_trial)"/>
    <param name="delete_after_each_trial" value="$(arg delete_after_each_trial)"/>

    <param name="pick_event_topic" value="/waste/pick_event"/>
    <param name="log_path" value="$(arg log_path)"/>
  </node>
</launch>
