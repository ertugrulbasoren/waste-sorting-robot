        </collision>
        <visual name="visual">
          <geometry><box><size>0.35 0.05 0.35</size></box></geometry>
          <material>
            <ambient>0 1 0 1</ambient>
            <diffuse>0 1 0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="wall_right">
        <pose>0 0.15 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.35 0.05 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
