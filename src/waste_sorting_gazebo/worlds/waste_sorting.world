<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="default">

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <physics type="ode">
      <gravity>0 0 -9.8</gravity>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- Conveyor -->
    <model name="ws_conveyor_belt">
      <static>true</static>
      <pose>0 0 0.06 0 0 0</pose>

      <link name="belt">
        <collision name="collision">
          <geometry>
            <box>
              <size>2.4 0.6 0.12</size>
            </box>
          </geometry>
        </collision>

        <visual name="visual">
          <geometry>
            <box>
              <size>2.4 0.6 0.12</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <plugin name="conveyor_motion_plugin" filename="libconveyor_motion_plugin.so">
        <belt_center>0 0 0.18</belt_center>
        <belt_size>2.4 0.6 0.12</belt_size>
        <belt_speed>0.22</belt_speed>
        <top_margin>0.20</top_margin>
        <min_object_z>0.11</min_object_z>
      </plugin>
    </model>

    <!-- RED BIN : plastic -->
    <model name="trash_bin_red">
      <static>true</static>
      <pose>1.38 -0.42 0 0 0 0</pose>

      <link name="base">
        <collision name="base_collision">
          <geometry>
            <box><size>0.35 0.35 0.05</size></box>
          </geometry>
        </collision>
        <visual name="base_visual">
          <geometry>
            <box><size>0.35 0.35 0.05</size></box>
          </geometry>
          <material>
            <ambient>0.85 0.0 0.0 1</ambient>
            <diffuse>0.85 0.0 0.0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="wall_left">
        <pose>0 -0.15 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.35 0.05 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.35 0.05 0.35</size></box></geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="wall_right">
        <pose>0 0.15 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.35 0.05 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.35 0.05 0.35</size></box></geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="wall_back">
        <pose>-0.15 0 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="wall_front">
        <pose>0.15 0 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Front sign -->
      <link name="front_sign">
        <pose>0.181 0 0.20 0 0 0</pose>

        <visual name="plate">
          <geometry><box><size>0.012 0.16 0.10</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>

        <!-- blue bottle icon -->
        <visual name="icon_body">
          <pose>0.008 0 0 0 0 0</pose>
          <geometry><box><size>0.003 0.020 0.050</size></box></geometry>
          <material>
            <ambient>0.15 0.45 1.0 1</ambient>
            <diffuse>0.15 0.45 1.0 1</diffuse>
          </material>
        </visual>

        <visual name="icon_neck">
          <pose>0.008 0 0.032 0 0 0</pose>
          <geometry><box><size>0.003 0.010 0.015</size></box></geometry>
          <material>
            <ambient>0.15 0.45 1.0 1</ambient>
            <diffuse>0.15 0.45 1.0 1</diffuse>
          </material>
        </visual>

        <visual name="icon_cap">
          <pose>0.008 0 0.044 0 0 0</pose>
          <geometry><box><size>0.003 0.012 0.006</size></box></geometry>
          <material>
            <ambient>0.05 0.20 0.70 1</ambient>
            <diffuse>0.05 0.20 0.70 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

