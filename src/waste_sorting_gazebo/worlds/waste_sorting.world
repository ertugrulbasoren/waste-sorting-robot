        <visual name="visual">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
          <material>
            <ambient>0 1 0 1</ambient>
            <diffuse>0 1 0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="wall_front">
        <pose>0.15 0 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
          <material>
            <ambient>0 1 0 1</ambient>
            <diffuse>0 1 0 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Front sign -->
      <link name="front_sign">
        <pose>0.181 0 0.20 0 0 0</pose>

        <visual name="plate">
          <geometry><box><size>0.012 0.16 0.10</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>

        <!-- paper lines -->
        <visual name="line1">
          <pose>0.008 0 0.025 0 0 0</pose>
          <geometry><box><size>0.003 0.090 0.008</size></box></geometry>
          <material>
            <ambient>0.20 0.35 0.90 1</ambient>
            <diffuse>0.20 0.35 0.90 1</diffuse>
          </material>
        </visual>

        <visual name="line2">
          <pose>0.008 0 0.005 0 0 0</pose>
          <geometry><box><size>0.003 0.100 0.008</size></box></geometry>
          <material>
            <ambient>0.20 0.35 0.90 1</ambient>
            <diffuse>0.20 0.35 0.90 1</diffuse>
          </material>
        </visual>

        <visual name="line3">
          <pose>0.008 0 -0.015 0 0 0</pose>
          <geometry><box><size>0.003 0.080 0.008</size></box></geometry>
          <material>
            <ambient>0.20 0.35 0.90 1</ambient>
            <diffuse>0.20 0.35 0.90 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- YELLOW BIN : metal -->
    <model name="trash_bin_yellow">
      <static>true</static>
      <pose>1.38 0.42 0 0 0 0</pose>

      <link name="base">
        <collision name="base_collision">
          <geometry><box><size>0.35 0.35 0.05</size></box></geometry>
        </collision>
        <visual name="base_visual">
          <geometry><box><size>0.35 0.35 0.05</size></box></geometry>
          <material>
            <ambient>0.9 0.85 0.1 1</ambient>
            <diffuse>0.9 0.85 0.1 1</diffuse>
