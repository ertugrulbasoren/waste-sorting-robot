      <link name="wall_back">
        <pose>-0.15 0 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
          <material>
            <ambient>1 1 0 1</ambient>
            <diffuse>1 1 0 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="wall_front">
        <pose>0.15 0 0.175 0 0 0</pose>
        <collision name="collision">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.35 0.35</size></box></geometry>
          <material>
            <ambient>1 1 0 1</ambient>
            <diffuse>1 1 0 1</diffuse>
          </material>
        </visual>
      </link>

      <!-- Front sign -->
      <link name="front_sign">
        <pose>0.181 0 0.20 0 0 0</pose>

        <visual name="plate">
          <geometry><box><size>0.012 0.16 0.10</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
          </material>
        </visual>

        <!-- can icon -->
        <visual name="can_body">
          <pose>0.008 0 0 0 0 0</pose>
          <geometry><box><size>0.003 0.040 0.050</size></box></geometry>
          <material>
            <ambient>0.70 0.70 0.70 1</ambient>
            <diffuse>0.75 0.75 0.75 1</diffuse>
          </material>
        </visual>

        <visual name="can_top">
          <pose>0.008 0 0.028 0 0 0</pose>
          <geometry><box><size>0.003 0.050 0.006</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.60 0.60 0.60 1</diffuse>
          </material>
        </visual>

        <visual name="can_bottom">
          <pose>0.008 0 -0.028 0 0 0</pose>
          <geometry><box><size>0.003 0.050 0.006</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.60 0.60 0.60 1</diffuse>
