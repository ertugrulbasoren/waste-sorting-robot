#!/usr/bin/env python3

import rospy
import random
from gazebo_msgs.srv import SpawnModel
from geometry_msgs.msg import Pose

def spawn_loop():
    rospy.init_node('spawn_trash_loop')

    rospy.wait_for_service('/gazebo/spawn_sdf_model')
    spawn_model = rospy.ServiceProxy('/gazebo/spawn_sdf_model', SpawnModel)

    model_path = "/home/ertugrulbasoren/waste_sorting_ws/src/waste_sorting_gazebo/models/trash_object_red/model.sdf"

    with open(model_path, "r") as f:
        model_xml = f.read()

    count = 0

    rate = rospy.Rate(0.5)  # 2 saniyede 1

    while not rospy.is_shutdown():

        pose = Pose()
        pose.position.x = -1 + random.uniform(-0.1, 0.1)
        pose.position.y = random.uniform(-0.1, 0.1)
        pose.position.z = 0.2

        model_name = "trash_" + str(count)

        try:
            spawn_model(model_name, model_xml, "", pose, "world")
            rospy.loginfo("Spawned: %s", model_name)
        except:
            rospy.logwarn("Spawn failed")

        count += 1
        rate.sleep()

if __name__ == "__main__":
    spawn_loop()#!/usr/bin/env python3

import rospy
from gazebo_msgs.srv import SpawnModel
from geometry_msgs.msg import Pose

def spawn():
    rospy.init_node('spawn_trash')

    rospy.wait_for_service('/gazebo/spawn_sdf_model')
    spawn_model = rospy.ServiceProxy('/gazebo/spawn_sdf_model', SpawnModel)

    with open("/home/ertugrulbasoren/waste_sorting_ws/src/waste_sorting_gazebo/models/trash_object_red/model.sdf", "r") as f:
        model_xml = f.read()

    pose = Pose()
    pose.position.x = -0.8
    pose.position.y = 0
    pose.position.z = 0.2

    spawn_model("trash1", model_xml, "", pose, "world")

    rospy.loginfo("Trash spawned!")

if __name__ == "__main__":
    spawn()
