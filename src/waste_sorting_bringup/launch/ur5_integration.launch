<launch>
  <!-- Robot description -->
  <include file="$(find ur_gazebo)/launch/inc/load_ur5.launch.xml">
    <arg name="transmission_hw_interface" value="hardware_interface/PositionJointInterface"/>
    <arg name="joint_limit_params" value="$(find ur_description)/config/ur5/joint_limits.yaml"/>
    <arg name="kinematics_params" value="$(find ur_description)/config/ur5/default_kinematics.yaml"/>
    <arg name="physical_params" value="$(find ur_description)/config/ur5/physical_parameters.yaml"/>
    <arg name="visual_params" value="$(find ur_description)/config/ur5/visual_parameters.yaml"/>
  </include>

  <!-- Robot state publisher -->
  <node pkg="robot_state_publisher"
        type="robot_state_publisher"
        name="ur5_robot_state_publisher"
        output="screen">
    <param name="publish_frequency" type="double" value="125"/>
    <param name="tf_prefix" value=""/>
  </node>

  <!-- Load controller settings -->
  <rosparam file="$(find ur_gazebo)/config/ur5_controllers.yaml" command="load"/>

  <!-- Spawn UR5 into already running Gazebo with stable initial joint pose -->
  <node name="spawn_ur5_model"
        pkg="gazebo_ros"
        type="spawn_model"
        args="-urdf -param robot_description -model ur5 -x 0.85 -y 0.55 -z 0.00 -J shoulder_pan_joint 0.0 -J shoulder_lift_joint -1.57 -J elbow_joint 1.57 -J wrist_1_joint -1.57 -J wrist_2_joint -1.57 -J wrist_3_joint 0.0"
        output="screen"
        respawn="false"/>

  <!-- Delay controller startup to avoid spawn/control race condition -->
  <node name="ur5_controller_spawner"
        pkg="controller_manager"
        type="spawner"
        args="joint_state_controller pos_joint_traj_controller"
        output="screen"
        respawn="false"
        launch-prefix="bash -c 'sleep 4; exec $0 $@'"/>
</launch>
